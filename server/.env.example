PORT=5000
NODE_ENV=development
# Comma-separated CORS origins are allowed; PUBLIC_CLIENT_URL is used in emails.
CLIENT_URL=http://localhost:5173
PUBLIC_CLIENT_URL=http://localhost:5173
# Transactions require a replica set. `docker compose up -d mongo` provides rs0.
MONGO_URI=mongodb://127.0.0.1:27017/shopflowai?replicaSet=rs0

ACCESS_TOKEN_SECRET=change-me
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=change-me
REFRESH_TOKEN_EXPIRY=7d

CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=shopflowai.dev@gmail.com
SMTP_PASS=change-me
EMAIL_FROM=shopflowai.dev@gmail.com

GEMINI_API_KEY=change-me
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_PUBLISHABLE_KEY=pk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
EXCHANGE_RATE_API_KEY=change-me
EXCHANGE_RATE_TIMEOUT_MS=5000

# Stripe inventory reservation and refund/cancellation outbox worker
PAYMENT_RESERVATION_MINUTES=30
COMMERCE_WORKER_INTERVAL_MS=30000
# Set true only when a separate worker process runs `npm run worker:once` on a schedule.
DISABLE_COMMERCE_WORKER=false

# Invoice / PDF module settings
INVOICE_CURRENCY=PKR
INVOICE_TAX_RATE=0
DEFAULT_DELIVERY_METHOD=Standard Delivery
SELLER_LEGAL_NAME=ShopFlowAI Technologies
SELLER_BUSINESS_ADDRESS=Okara, Punjab, Pakistan
SELLER_TAX_ID=Tax/VAT/GST ID: N/A
SELLER_SUPPORT_EMAIL=shopflowai.dev@gmail.com
SELLER_SUPPORT_PHONE=+923346956216

# Email notification settings
ADMIN_NOTIFICATION_EMAILS=shopflowai.dev@gmail.com
LOW_STOCK_THRESHOLD=5

# Redis cache settings (disabled by default; set CACHE_ENABLED=true when Redis is available)
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379
CACHE_TTL_PRODUCTS=120
CACHE_TTL_PRODUCT_DETAIL=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_CATEGORY_DETAIL=600
CACHE_TTL_ANALYTICS=300
